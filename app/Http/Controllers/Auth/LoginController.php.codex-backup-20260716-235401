<?php

namespace App\Http\Controllers\Auth;

use App\Http\Controllers\Controller;
use App\Models\Company;
use App\Models\User;
use Illuminate\Http\RedirectResponse;
use Illuminate\Http\Request;
use Illuminate\Support\Collection;
use Illuminate\Support\Facades\Auth;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Hash;
use Illuminate\Support\Facades\RateLimiter;
use Illuminate\Support\Facades\Schema;
use Illuminate\Support\Str;
use Illuminate\Validation\ValidationException;
use Laravel\Socialite\Facades\Socialite;
use Throwable;

class LoginController extends Controller
{
  public function index()
  {
    return view('auth.login');
  }

  public function login(Request $request): RedirectResponse
  {
    $request->validate([
      'email' => ['required', 'email:rfc,', 'max:255'],
      'password' => ['required', 'string', 'max:255'],
      'remember' => ['nullable', 'boolean'],
    ]);

    $email = Str::lower(trim($request->input('email')));
    $password = $request->input('password');
    $remember = $request->boolean('remember');
    $throttleKey = $this->throttleKey($email, $request);

    if (RateLimiter::tooManyAttempts($throttleKey, 5)) {
      $seconds = RateLimiter::availableIn($throttleKey);

      throw ValidationException::withMessages([
        'email' => "Terlalu banyak percobaan login. Coba lagi dalam {$seconds} detik.",
      ]);
    }

    $user = User::query()
      ->whereRaw('LOWER(email) = ?', [$email])
      ->first();

    if (!$user || !Hash::check($password, (string) $user->password)) {
      RateLimiter::hit($throttleKey, 60);
      $this->logLogin(null, $email, 'password', 'failed', $request, 'Invalid credentials');

      throw ValidationException::withMessages([
        'email' => 'Email atau password tidak sesuai.',
      ]);
    }

    if (!$this->userCanLogin($user)) {
      RateLimiter::hit($throttleKey, 60);
      $this->safeUpdateUser($user, [
        'last_failed_login_at' => now(),
      ]);
      $this->logLogin($user, $email, 'password', 'blocked', $request, 'User inactive, locked, or not active');

      throw ValidationException::withMessages([
        'email' => 'Akun tidak dapat login. Silakan hubungi admin.',
      ]);
    }

    RateLimiter::clear($throttleKey);

    Auth::login($user, $remember);
    $request->session()->regenerate();

    $this->markLoginSuccess($user, $request);
    $this->logLogin($user, $email, 'password', 'success', $request);

    return $this->afterAuthenticated($request, $user);
  }

  public function redirectToGoogle(): RedirectResponse
  {
    return Socialite::driver('google')
      ->scopes(['openid', 'profile', 'email'])
      ->redirect();
  }

  public function handleGoogleCallback(Request $request): RedirectResponse
  {
    try {
      $googleUser = Socialite::driver('google')->user();

      $email = Str::lower(trim((string) $googleUser->getEmail()));

      if (!$email) {
        return redirect()
          ->route('login')
          ->withErrors(['email' => 'Email Google tidak ditemukan.']);
      }

      $user = User::query()
        ->whereRaw('LOWER(email) = ?', [$email])
        ->first();

      if (!$user) {
        $this->logLogin(null, $email, 'google', 'failed', $request, 'Google email not registered');

        return redirect()
          ->route('login')
          ->withErrors(['email' => 'Akun Google belum terdaftar di sistem.']);
      }

      if (!$this->userCanLogin($user)) {
        $this->logLogin($user, $email, 'google', 'blocked', $request, 'User inactive, locked, or not active');

        return redirect()
          ->route('login')
          ->withErrors(['email' => 'Akun tidak dapat login. Silakan hubungi admin.']);
      }

      $updates = [];

      if (Schema::hasColumn('users', 'google_id') && blank($user->google_id)) {
        $updates['google_id'] = $googleUser->getId();
      }

      if (Schema::hasColumn('users', 'avatar') && blank($user->avatar) && $googleUser->getAvatar()) {
        $updates['avatar'] = $googleUser->getAvatar();
      }

      if ($updates) {
        $this->safeUpdateUser($user, $updates);
      }

      Auth::login($user, true);
      $request->session()->regenerate();

      $this->markLoginSuccess($user, $request);
      $this->logLogin($user, $email, 'google', 'success', $request);

      return $this->afterAuthenticated($request, $user);
    } catch (Throwable $e) {
      report($e);

      return redirect()
        ->route('login')
        ->withErrors(['email' => 'Login Google gagal. Silakan coba lagi.']);
    }
  }

  public function selectCompany(Request $request)
  {
    $user = $request->user();

    $companies = $this->getActiveCompaniesForUser($user);

    if ($companies->count() === 1) {
      $this->setActiveCompanyToSession($request, $companies->first());

      return redirect()->intended(route('dashboard'));
    }

    if ($companies->isEmpty()) {
      Auth::logout();
      $request->session()->invalidate();
      $request->session()->regenerateToken();

      return redirect()
        ->route('login')
        ->withErrors(['email' => 'Akun belum memiliki akses company aktif.']);
    }

    return view('auth.select-company', [
      'companies' => $companies,
    ]);
  }

  public function setCompany(Request $request): RedirectResponse
  {
    $request->validate([
      'company_id' => ['required', 'integer'],
    ]);

    $companyId = (int) $request->input('company_id');
    $user = $request->user();

    $company = $this->getActiveCompaniesForUser($user)
      ->firstWhere('id', $companyId);

    if (!$company) {
      return back()->withErrors([
        'company_id' => 'Company tidak valid atau tidak aktif.',
      ]);
    }

    $this->setActiveCompanyToSession($request, $company);

    return redirect()->intended(route('dashboard'));
  }

  public function logout(Request $request): RedirectResponse
  {
    Auth::logout();

    $request->session()->forget([
      'company_id',
      'company_name',
    ]);

    $request->session()->invalidate();
    $request->session()->regenerateToken();

    return redirect()->route('login')->with('success', 'Berhasil logout.');
  }

  private function afterAuthenticated(Request $request, User $user): RedirectResponse
  {
    $companies = $this->getActiveCompaniesForUser($user);

    if ($companies->isEmpty()) {
      Auth::logout();
      $request->session()->invalidate();
      $request->session()->regenerateToken();

      return redirect()
        ->route('login')
        ->withErrors(['email' => 'Akun belum memiliki akses company aktif.']);
    }

    if ($companies->count() === 1) {
      $this->setActiveCompanyToSession($request, $companies->first());

      return redirect()->intended(route('dashboard'));
    }

    return redirect()->route('company.select');
  }

  private function setActiveCompanyToSession(Request $request, Company $company): void
  {
    $request->session()->put([
      'company_id' => $company->id,
      'company_name' => $company->name ?? $company->company_name ?? 'Company',
    ]);

    if (function_exists('setPermissionsTeamId')) {
      setPermissionsTeamId($company->id);
    }
  }

  private function getActiveCompaniesForUser(User $user): Collection
  {
    $companies = collect();

    if (method_exists($user, 'activeCompanies')) {
      try {
        $companies = $user->activeCompanies()->get();
      } catch (Throwable $e) {
        report($e);
        $companies = collect();
      }
    }

    if ($companies->isEmpty() && Schema::hasColumn('users', 'company_id') && $user->company_id) {
      $company = Company::query()
        ->whereKey($user->company_id)
        ->active()
        ->first();

      if ($company) {
        $companies->push($company);
      }
    }

    return $companies
      ->unique('id')
      ->values();
  }

  private function userCanLogin(User $user): bool
  {
    if (Schema::hasColumn('users', 'is_active') && !$user->is_active) {
      return false;
    }

    if (Schema::hasColumn('users', 'status') && $user->status !== 'active') {
      return false;
    }

    if (Schema::hasColumn('users', 'is_locked') && $user->is_locked) {
      return false;
    }

    if (Schema::hasColumn('users', 'locked_at') && !blank($user->locked_at)) {
      return false;
    }

    return true;
  }

  private function markLoginSuccess(User $user, Request $request): void
  {
    $this->safeUpdateUser($user, [
      'last_login_at' => now(),
      'last_login_ip' => $request->ip(),
      'last_login_user_agent' => Str::limit((string) $request->userAgent(), 500, ''),
      'last_activity_at' => now(),
    ]);
  }

  private function safeUpdateUser(User $user, array $data): void
  {
    $updates = [];

    foreach ($data as $column => $value) {
      if (Schema::hasColumn('users', $column)) {
        $updates[$column] = $value;
      }
    }

    if ($updates) {
      $user->forceFill($updates)->save();
    }
  }

  private function logLogin(?User $user, ?string $email, string $provider, string $status, Request $request, ?string $message = null): void
  {
    if (!Schema::hasTable('user_login_logs')) {
      return;
    }

    try {
      $payload = [
        'user_id' => $user?->id,
        'company_id' => session('company_id'),
        'email' => $email,
        'provider' => $provider,
        'status' => $status,
        'message' => $message,
        'ip_address' => $request->ip(),
        'user_agent' => Str::limit((string) $request->userAgent(), 1000, ''),
        'logged_in_at' => now(),
        'created_at' => now(),
        'updated_at' => now(),
      ];

      $insert = [];

      foreach ($payload as $column => $value) {
        if (Schema::hasColumn('user_login_logs', $column)) {
          $insert[$column] = $value;
        }
      }

      if ($insert) {
        DB::table('user_login_logs')->insert($insert);
      }
    } catch (Throwable $e) {
      report($e);
    }
  }

  private function throttleKey(string $email, Request $request): string
  {
    return Str::transliterate(Str::lower($email) . '|' . $request->ip());
  }
}
