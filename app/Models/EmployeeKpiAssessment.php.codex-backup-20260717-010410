<?php

namespace App\Models;

use Illuminate\Database\Eloquent\Builder;
use Illuminate\Database\Eloquent\Model;
use Illuminate\Database\Eloquent\SoftDeletes;
use Illuminate\Database\Eloquent\Relations\BelongsTo;
use Illuminate\Database\Eloquent\Relations\HasMany;

class EmployeeKpiAssessment extends Model
{
    use SoftDeletes;

    protected $guarded = ['id'];
    protected $casts = ['total_score' => 'decimal:2', 'bonus_maximum' => 'decimal:2', 'bonus_amount' => 'decimal:2', 'submitted_at' => 'datetime', 'approved_at' => 'datetime'];

    public function company(): BelongsTo { return $this->belongsTo(Company::class); }
    public function employee(): BelongsTo { return $this->belongsTo(Employee::class); }
    public function position(): BelongsTo { return $this->belongsTo(Position::class); }
    public function standard(): BelongsTo { return $this->belongsTo(KpiStandard::class, 'kpi_standard_id'); }
    public function assessor(): BelongsTo { return $this->belongsTo(User::class, 'assessor_id'); }
    public function approver(): BelongsTo { return $this->belongsTo(User::class, 'approved_by'); }
    public function items(): HasMany { return $this->hasMany(EmployeeKpiAssessmentItem::class); }
    public function scopeForCompany(Builder $query, int $companyId): Builder { return $query->where('company_id', $companyId); }
}
